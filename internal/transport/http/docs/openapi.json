{
  "openapi": "3.0.3",
  "info": {
    "title": "Task Service API",
    "version": "1.0.0",
    "description": "CRUD API for tasks with recurrence support. Supports daily, monthly, specific dates, and even/odd day recurrence."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "Tasks",
      "description": "Operations with tasks (supports recurring tasks)"
    }
  ],
  "paths": {
    "/api/v1/tasks": {
      "get": {
        "tags": ["Tasks"],
        "summary": "List tasks with optional filtering",
        "parameters": [
          {
            "name": "parent_task_id",
            "in": "query",
            "schema": { "type": "integer", "format": "int64" },
            "description": "Filter by parent template ID to get task instances"
          },
          {
            "name": "recurrence_type",
            "in": "query",
            "schema": { 
              "type": "string",
              "enum": ["daily", "monthly", "specific_dates", "even_odd"]
            },
            "description": "Filter tasks by recurrence type"
          }
        ],
        "responses": {
          "200": {
            "description": "Task list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Task" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Tasks"],
        "summary": "Create task (simple or recurring template)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTaskRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created task",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/v1/tasks/{id}": {
      "get": {
        "tags": ["Tasks"],
        "summary": "Get task by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Task",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Tasks"],
        "summary": "Update task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateTaskRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated task",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Tasks"],
        "summary": "Delete task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "CreateTaskRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Prepare release"
          },
          "description": {
            "type": "string",
            "example": "Collect release notes and check migrations"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "new"
          },
          "recurrence_type": {
            "type": "string",
            "enum": ["none", "daily", "monthly", "specific_dates", "even_odd"],
            "description": "Type of recurrence. Omit or set to 'none' for simple tasks.",
            "example": "daily"
          },
          "recurrence_config": {
            "type": "object",
            "description": "Configuration for recurrence. Required if recurrence_type is set.",
            "oneOf": [
              {
                "title": "Daily config",
                "properties": {
                  "interval": { "type": "integer", "minimum": 1, "example": 3 }
                }
              },
              {
                "title": "Monthly config",
                "properties": {
                  "days": { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 30 }, "example": [5, 20] }
                }
              },
              {
                "title": "Specific dates config",
                "properties": {
                  "dates": { "type": "array", "items": { "type": "string", "format": "date" }, "example": ["2026-05-01", "2026-05-15"] }
                }
              },
              {
                "title": "Even/Odd config",
                "properties": {
                  "parity": { "type": "string", "enum": ["even", "odd"], "example": "even" }
                }
              }
            ]
          }
        },
        "examples": {
          "simple_task": {
            "summary": "Simple task without recurrence",
            "value": {
              "title": "Review pull request",
              "description": "Check code changes and merge",
              "status": "new"
            }
          },
          "daily_task": {
            "summary": "Daily recurring task",
            "value": {
              "title": "Daily standup",
              "description": "Join team daily meeting",
              "status": "new",
              "recurrence_type": "daily",
              "recurrence_config": { "interval": 1 }
            }
          },
          "monthly_task": {
            "summary": "Monthly recurring task",
            "value": {
              "title": "Monthly report",
              "description": "Generate monthly sales report",
              "status": "new",
              "recurrence_type": "monthly",
              "recurrence_config": { "days": [5, 20] }
            }
          },
          "specific_dates_task": {
            "summary": "Task on specific dates",
            "value": {
              "title": "Client meeting",
              "description": "Meeting with important client",
              "status": "new",
              "recurrence_type": "specific_dates",
              "recurrence_config": { "dates": ["2026-05-01", "2026-05-15"] }
            }
          },
          "even_days_task": {
            "summary": "Task on even days of month",
            "value": {
              "title": "Inventory check",
              "description": "Check warehouse inventory",
              "status": "new",
              "recurrence_type": "even_odd",
              "recurrence_config": { "parity": "even" }
            }
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Prepare release"
          },
          "description": {
            "type": "string",
            "example": "Collect release notes and check migrations"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "in_progress"
          },
          "recurrence_type": {
            "type": "string",
            "enum": ["none", "daily", "monthly", "specific_dates", "even_odd"],
            "description": "Type of recurrence"
          },
          "recurrence_config": {
            "type": "object",
            "description": "Configuration for recurrence"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "example": 1 },
          "title": { "type": "string", "example": "Prepare release" },
          "description": { "type": "string", "example": "Collect release notes and check migrations" },
          "status": { "type": "string", "enum": ["new", "in_progress", "done"], "example": "new" },
          "created_at": { "type": "string", "format": "date-time", "example": "2026-03-24T00:00:00Z" },
          "updated_at": { "type": "string", "format": "date-time", "example": "2026-03-24T00:00:00Z" },
          "recurrence_type": { "type": "string", "enum": ["none", "daily", "monthly", "specific_dates", "even_odd"], "example": "daily" },
          "recurrence_config": {
            "type": "object",
            "description": "Recurrence configuration",
            "example": { "interval": 1 }
          },
          "parent_task_id": {
            "type": "integer",
            "format": "int64",
            "description": "ID of parent template for task instances",
            "example": 5
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "task not found" }
        }
      }
    }
  }
}